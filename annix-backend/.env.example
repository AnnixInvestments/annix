# JWT Configuration
JWT_SECRET=your_generated_secret_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=annix-api
JWT_AUDIENCE=annix-app

# WebAuthn / Passkey Configuration
# RP ID is the apex domain users see (no scheme, no port). For local development use 'localhost'.
# In production set to the apex domain shared by all login subdomains, e.g. 'annix.co.za'.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Annix
# Comma-separated list of allowed origins (full URLs incl. scheme + port if non-default).
WEBAUTHN_ORIGIN=http://localhost:3000

# Admin User Setup (required for initial migration)
ADMIN_INITIAL_PASSWORD=your_secure_admin_password_here

# Database Configuration (MongoDB Atlas — system of record)
MONGODB_URI=mongodb+srv://user:password@your-cluster.mongodb.net
MONGO_DATABASE=annix_dev
# Annix Orbit runs on its own MongoDB cluster
ORBIT_MONGODB_URI=mongodb+srv://user:password@your-orbit-cluster.mongodb.net
ORBIT_MONGO_DATABASE=orbit_dev

# Application Configuration
NODE_ENV=development
PORT=4001

# Security Feature Flags (set to 'true' to DISABLE in development only)
# WARNING: All flags default to 'false' (security ON). Only set to 'true' for local development.
DISABLE_PASSWORD_VERIFICATION=false
DISABLE_EMAIL_VERIFICATION=false
DISABLE_ACCOUNT_STATUS_CHECK=false
DISABLE_IP_MISMATCH_CHECK=false
DISABLE_DEVICE_FINGERPRINT=false

# Storage Configuration
# Options: 's3' (default, recommended) or 'local' (development only)
# WARNING: Local storage is deprecated - files will be lost on redeployment
STORAGE_TYPE=s3

# AWS S3 Configuration (required for STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=af-south-1
AWS_S3_BUCKET=annix-sync-files
AWS_S3_URL_EXPIRATION=3600

# Local Storage Configuration (only used when STORAGE_TYPE=local)
# DEPRECATED: Only use for local development
# UPLOAD_DIR=./uploads
API_BASE_URL=http://localhost:4001/api
# Optional: HMAC secret for short-lived signed /api/files URLs. Falls back to JWT_SECRET.
# FILE_URL_SIGNING_SECRET=

# External API Keys (add as needed)
# GOOGLE_API_KEY=your_google_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Nix AI Assistant
# At least one AI provider API key is required for chat and document extraction
#
# Gemini Configuration
# GEMINI_API_KEY=your_gemini_api_key_here
# Cheap default for all chat/extraction. CV extraction + OCR override to gemini-2.5-flash in code for accuracy.
GEMINI_CHAT_MODEL=gemini-2.0-flash
#
# Claude/Anthropic Configuration
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
#
# Provider Selection (auto, gemini, or claude)
# - auto: Uses Gemini if available, falls back to Claude
# - gemini: Prefer Gemini, fall back to Claude if unavailable
# - claude: Prefer Claude, fall back to Gemini if unavailable
# AI_CHAT_PROVIDER=auto
# AI_EXTRACTION_PROVIDER=auto

# Email Service Configuration
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password_here
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Annix
SUPPORT_EMAIL=support@example.com

# Inbound email auto-cleanup: comma-separated domains whose mailboxes are
# owned by us. After an inbound message is fully processed (attachments stored,
# records written), it is deleted from the INBOX only when its mailbox domain is
# listed here, keeping owned mailboxes within hosting quota. Mailboxes on other
# (e.g. customer-owned) domains are never auto-deleted. Empty = never delete.
INBOUND_AUTO_DELETE_DOMAINS=example.com

# Inbound mailbox auto-provisioning (on customer onboarding approval). When a
# customer is approved, a <company-slug>-app@<domain> mailbox config is created
# (disabled) for their inbox-app and the credentials are emailed to the notify
# address so the mailbox can be created on the hosting panel. Provisioning is
# skipped if HOST or DOMAIN is unset.
INBOUND_PROVISION_HOST=mail.example.com
INBOUND_PROVISION_PORT=993
INBOUND_PROVISION_TLS=true
INBOUND_PROVISION_DOMAIN=example.com
# Where provisioning credential emails are sent (falls back to SUPPORT_EMAIL).
INBOUND_PROVISION_NOTIFY_EMAIL=emails@example.com

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:3000

# GitHub Integration (for customer feedback issues)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# GITHUB_REPO_OWNER=AnnixInvestments
# GITHUB_REPO_NAME=annix

# Feedback environment routing — set ONLY on the test Fly app (annix-app-test).
# When FEEDBACK_ENV=test, feedback is routed to FEEDBACK_TEST_ISSUE instead of the
# per-app production tracker, Claude is told to assess-only (no fix / no PR), and the
# support email + admin conversation are suppressed. Leave both UNSET on prod/staging.
# FEEDBACK_ENV=test
# FEEDBACK_TEST_ISSUE=344

# Calendar Integration - Google OAuth
# GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret

# Calendar Integration - Microsoft OAuth
# MICROSOFT_CLIENT_ID=your_microsoft_client_id
# MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# Token Encryption Key (64-char hex string for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOKEN_ENCRYPTION_KEY=

# Web Push (VAPID) — powers browser push notifications, shared by Annix Orbit
# (seeker "matches are ready") AND Stock Control. Both backends read the SAME
# WebPushChannel, so one keypair per environment serves every app. If either
# key is unset, web push self-disables and sends silently no-op (in-app banners
# still work). Keys are PER-ENVIRONMENT — each Fly app (annix-app /
# annix-app-test) needs its own pair; do NOT reuse a pair across environments.
# Generate with: npx web-push generate-vapid-keys
# Set as Fly secrets, never commit real values. See docs/notifications.md.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:info@annix.co.za