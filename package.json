{
  "name": "annix-fullstack",
  "version": "0.1.0",
  "description": "Full-stack application with NestJS backend and Next.js frontend",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "claude-swarm": "claude-swarm",
    "test:backend": "cd annix-backend && pnpm test",
    "test:backend:scoped": "cd annix-backend && pnpm exec jest --forceExit --changedSince=origin/main --passWithNoTests",
    "test:frontend": "cd annix-frontend && pnpm type-check:prepush && pnpm test",
    "test:all": "pnpm test:backend && pnpm test:frontend",
    "test:coverage": "cd annix-backend && pnpm test:cov",
    "test:watch": "cd annix-backend && pnpm test:watch",
    "test:e2e": "cd annix-backend && pnpm test:e2e",
    "dev:backend": "cd annix-backend && pnpm start:dev",
    "dev:backend:migrate": "cd annix-backend && pnpm start:dev:migrate",
    "env:setup": "claude-swarm env setup",
    "env:list": "claude-swarm env list",
    "dev:frontend": "cd annix-frontend && pnpm dev",
    "dev:frontend:clean": "npx kill-port 3000 && cd annix-frontend && rm -rf .next/cache/turbopack .next/cache/swc && pnpm dev",
    "dev": "node scripts/check-hooks-installed.ts && claude-swarm start",
    "stop": "claude-swarm stop",
    "kill-ports": "npx kill-port 3000 4001",
    "dev:clean": "pnpm kill-ports && pnpm dev",
    "dev:direct": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "build:backend": "cd annix-backend && pnpm build",
    "build:frontend": "cd annix-frontend && pnpm build",
    "build": "pnpm build:backend && pnpm build:frontend",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "lint:backend": "cd annix-backend && pnpm lint",
    "lint:frontend": "cd annix-frontend && pnpm lint",
    "type-check": "cd annix-frontend && pnpm type-check",
    "start:prod": "NEXT_PUBLIC_API_URL=/api pnpm build && cd annix-backend && npx ts-node --project tsconfig.json --transpile-only ./node_modules/typeorm/cli -d ./src/config/data-source.ts migration:run && NODE_ENV=production PORT=4000 FRONTEND_URL=http://localhost:4000 node dist/src/main.js",
    "prepare": "node scripts/check-hooks-installed.ts"
  },
  "pnpm": {
    "patchedDependencies": {
      "@tanstack/query-core@5.90.20": "patches/@tanstack__query-core@5.90.20.patch"
    },
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "@nestjs/core": "^11.1.18",
      "@xmldom/xmldom": "^0.8.13",
      "ajv@6": "^6.14.0",
      "ajv@8": "^8.18.0",
      "axios": "^1.16.0",
      "basic-ftp": "^5.3.1",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.3",
      "defu": "^6.1.5",
      "dompurify": "^3.4.0",
      "fast-uri": "^3.1.2",
      "fast-xml-parser@5": "^5.7.0",
      "file-type@21": "^21.3.2",
      "flatted": "^3.4.2",
      "follow-redirects": "^1.16.0",
      "handlebars": "^4.7.9",
      "ip-address": "^10.1.1",
      "lodash": "^4.18.0",
      "lodash-es": "^4.18.0",
      "mermaid": "^11.15.0",
      "minimatch@3": "^3.1.4",
      "multer": "^2.1.1",
      "minimatch@5": "^5.1.8",
      "minimatch@9": "^9.0.7",
      "minimatch@10": "^10.2.3",
      "path-to-regexp@8": "^8.4.0",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4",
      "postcss": "^8.5.10",
      "qs": "^6.15.2",
      "rollup@4": "^4.59.0",
      "semver@5": "^5.7.2",
      "serialize-javascript": "^7.0.5",
      "shell-quote": "^1.8.4",
      "tmp": "^0.2.6",
      "underscore": "^1.13.8",
      "uuid": "^11.1.1",
      "vite": "^7.3.2",
      "ws@8": "^8.20.1",
      "yaml@1": "^1.10.3",
      "yaml@2": "^2.8.3"
    }
  },
  "devDependencies": {
    "@annix/claude-swarm": "0.1.35",
    "@biomejs/biome": "2.4.14",
    "@inquirer/prompts": "^8.2.0",
    "@types/node": "^25.0.9",
    "chalk": "^4.1.2",
    "concurrently": "^8.2.2",
    "kill-port": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
