# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup
.env.prod-db
annix-backend/configs/

# Build artifacts
annix-frontend-latest.tar.gz
annix-backend-latest.tar.gz

# IDE files
.idea
.claude/*
!.claude/skills/
!.claude/skills/**

# Log files
backend-dev.log
frontend-dev.log
.pcm-app.log
.claude-swarm-*.log
logs/
.claude-swarm/registry.json

# OS files
.DS_Store
Thumbs.db

# Node modules
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Subdirectory lockfiles (use root lockfile only)
annix-backend/pnpm-lock.yaml
annix-frontend/pnpm-lock.yaml

# Build outputs
dist/
build/

# User uploads
annix-backend/uploads/

# OCR training data (auto-downloaded by tesseract.js)
*.traineddata

# Prevent accidental .js file commits (use .ts instead)
# This excludes node_modules which is already ignored
*.js
!*.config.js
!*.config.mjs
!annix-frontend/public/sw.js

# Deployment docs with secrets - DO NOT COMMIT
FLY_DEPLOYMENT_TECHNICAL_DOCS.md

# Secret patterns file - contains actual secrets for detection
.secret-patterns

# Dev utility scripts
annix-backend/query-docs.ts

# Local sync clone (root-level only — must stay anchored so it doesn't also
# ignore the app source dir annix-frontend/src/app/annix/)
/annix/

# Voice filter artifacts
voice-filter/crash.log
voice-filter/start-filter.vbs

# Windows nul files (created accidentally on Windows)
nul
.parallel-claude-projects.json

# Scratch / temp working files (root-level only — anchored so nested tmp/
# dirs in app source aren't ignored). Already-tracked files such as
# tmp/rfq-baseline.md stay tracked.
/tmp/

# Cross-session DB-env awareness state (scripts/db-env.mjs)
.claude-swarm/db-env-state.json

# Local PDF/debug renders (scripts/render-pdf.py output)
pdf-renders/
tmp-rfq-img/
/tmp-*.mjs
/tmp-*.py
non-vcs/
