#!/bin/bash
#
# Pre-commit hook for secret detection
# Requirements: bash, grep (works with Git Bash on Windows, native on macOS/Linux)
#

set -e

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SECRETS_PATTERNS_FILE="$ROOT_DIR/.secret-patterns"

echo "Running secret detection scan..."

# Get staged files (only text files, exclude certain paths)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -v -E '(\.secret-patterns|pnpm-lock\.yaml|package-lock\.json|\.gitignore|\.githooks/)' || true)

if [ -z "$STAGED_FILES" ]; then
    echo "No files to scan."
    exit 0
fi

FOUND_SECRETS=0

# Check for literal patterns from the secrets pattern file (fixed-string matching)
if [ -f "$SECRETS_PATTERNS_FILE" ]; then
    while IFS= read -r pattern || [ -n "$pattern" ]; do
        # Skip empty lines and comments
        case "$pattern" in
            ''|\#*) continue ;;
        esac

        for file in $STAGED_FILES; do
            if [ -f "$file" ]; then
                # Search for literal string in the staged version of the file (-F = fixed strings)
                if git show ":$file" 2>/dev/null | grep -qF "$pattern"; then
                    echo "ERROR: Potential secret found in $file"
                    echo "  Pattern: $pattern"
                    FOUND_SECRETS=1
                fi
            fi
        done
    done < "$SECRETS_PATTERNS_FILE"
fi

# Additional checks for common secret patterns
COMMON_PATTERNS=(
    # AWS Access Key ID
    'AKIA[0-9A-Z]{16}'

    # JWT secrets (64-char hex)
    'JWT_SECRET.*[a-f0-9]{64}'

    # Private keys
    'BEGIN.*PRIVATE KEY'

    # Fly.io tokens
    'FlyV1.*fm2_'

    # Google API keys
    'AIza[0-9A-Za-z_-]{35}'
)

for pattern in "${COMMON_PATTERNS[@]}"; do
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            if git show ":$file" 2>/dev/null | grep -qE "$pattern"; then
                echo "ERROR: Potential secret pattern found in $file"
                echo "  Pattern type: $(printf '%.50s' "$pattern")..."
                FOUND_SECRETS=1
            fi
        fi
    done
done

if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo "=========================================="
    echo "COMMIT BLOCKED: Potential secrets detected"
    echo "=========================================="
    echo ""
    echo "If these are false positives, you can:"
    echo "  1. Add the pattern to .secret-patterns with a comment explaining why it's safe"
    echo "  2. Use 'git commit --no-verify' to bypass (NOT RECOMMENDED)"
    echo ""
    exit 1
fi

echo "Secret scan passed - no secrets detected."

# Version bump check for app changes
check_version_bump() {
    local app_name="$1"
    local version_file="$2"
    shift 2
    local frontend_patterns=("$@")

    local files_changed=0
    for pattern in "${frontend_patterns[@]}"; do
        local count=$(git diff --cached --name-only --diff-filter=ACMR | grep -c "^${pattern}" || true)
        files_changed=$((files_changed + count))
    done

    local version_changed=$(git diff --cached --name-only --diff-filter=ACMR | grep -c "^${version_file}$" || true)

    if [ "$files_changed" -gt 0 ] && [ "$version_changed" -eq 0 ]; then
        local non_test=$(git diff --cached --name-only --diff-filter=ACMR | grep -E "$(printf '%s|' "${frontend_patterns[@]}" | sed 's/|$//')" | grep -cvE '\.(spec|test)\.ts$' || true)
        if [ "$non_test" -gt 0 ]; then
            echo ""
            echo "  WARNING: ${app_name} files changed but version not bumped."
            echo "   Remember to update: $version_file"
            echo "   (patch for fixes, minor for features, major for breaking changes)"
            echo ""
        fi
    fi
}

check_version_bump "Stock Control" \
    "annix-frontend/src/app/stock-control/config/version.ts" \
    "annix-frontend/src/app/stock-control/" "annix-backend/src/stock-control/"

check_version_bump "RFQ" \
    "annix-frontend/src/app/lib/config/rfq/version.ts" \
    "annix-frontend/src/app/admin/" "annix-frontend/src/app/customer/" "annix-frontend/src/app/supplier/" "annix-frontend/src/app/lib/config/rfq/" "annix-backend/src/rfq/" "annix-backend/src/boq/"

check_version_bump "AU Rubber" \
    "annix-frontend/src/app/au-rubber/config/version.ts" \
    "annix-frontend/src/app/au-rubber/" "annix-backend/src/au-rubber/"

check_version_bump "FieldFlow/Voice" \
    "annix-frontend/src/app/annix-rep/config/version.ts" \
    "annix-frontend/src/app/annix-rep/"

check_version_bump "Annix Rep" \
    "annix-frontend/src/app/annix-rep/config/annix-rep-version.ts" \
    "annix-frontend/src/app/annix-rep/"

check_version_bump "Annix Orbit" \
    "annix-frontend/src/app/annix/orbit/config/version.ts" \
    "annix-frontend/src/app/annix/orbit/" "annix-backend/src/annix-orbit/"

# ─── Fast pre-commit checks ────────────────────────────────────────────
# These catch issues that otherwise only surface during the slow pre-push
# pipeline (biome, type-check, spec dependency mismatches).

STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|json)$' || true)

# 1. Biome lint on staged files only (prevents formatting failures at push).
#    Use biome's built-in `--staged` flag so we don't have to pass the file
#    list on the command line — that hits Windows' ~8 KB cmdline limit on
#    large refactors and renames (>~100 staged files).
if [ -n "$STAGED_TS_FILES" ]; then
    echo ""
    echo "Running biome check on staged files..."
    BIOME_OUTPUT=$(pnpm biome check --staged 2>&1) && BIOME_EXIT=0 || BIOME_EXIT=$?
    if [ $BIOME_EXIT -ne 0 ] && ! echo "$BIOME_OUTPUT" | grep -q "No files were processed"; then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Biome check failed"
        echo "============================================"
        echo "Run 'npx biome check --write --unsafe .' to auto-fix."
        echo ""
        exit 1
    fi
    echo "Biome check passed."
fi

# 2. Backend spec dependency check — if a service, controller OR module
#    changed, verify its spec file can still resolve all providers. Uses
#    import-graph grep to find spec files since naming is not always
#    ${basename}.spec.ts (e.g. rfq.controller.ts is tested by
#    rfq-pump.controller.spec.ts).
#    The related specs are run IN FULL (not filtered to a "should be defined"
#    test). Filtering by `-t "should be defined"` silently SKIPPED any spec
#    that lacks a literally-named "should be defined" test — Jest reported
#    "1 skipped, 0 of 1 total" and exited 0, so its beforeEach (where
#    createTestingModule resolves DI) never ran and a missing mock provider
#    slipped through to pre-push. Running the full file guarantees the
#    TestingModule compilation executes, which is what throws on a missing
#    provider regardless of how the spec names its tests.
STAGED_BACKEND_SERVICES=$(echo "$STAGED_TS_FILES" | grep -E '^annix-backend/src/.*\.service\.ts$' | grep -v '\.spec\.ts$' || true)
STAGED_BACKEND_CONTROLLERS=$(echo "$STAGED_TS_FILES" | grep -E '^annix-backend/src/.*\.controller\.ts$' | grep -v '\.spec\.ts$' || true)
STAGED_BACKEND_MODULES=$(echo "$STAGED_TS_FILES" | grep -E '^annix-backend/src/.*\.module\.ts$' | grep -v '\.spec\.ts$' || true)

if [ -n "$STAGED_BACKEND_SERVICES" ] || [ -n "$STAGED_BACKEND_CONTROLLERS" ] || [ -n "$STAGED_BACKEND_MODULES" ]; then
    echo ""
    echo "Checking backend spec dependencies for changed services, controllers and modules..."
    SPEC_FAIL=0
    SPECS_TO_RUN=""

    # Build a deduplicated list of spec files to run. For each changed source
    # file, collect (a) the same-name spec if it exists, and (b) any spec file
    # in the same directory that imports the source file by its basename.
    for src_file in $STAGED_BACKEND_SERVICES $STAGED_BACKEND_CONTROLLERS $STAGED_BACKEND_MODULES; do
        src_dir=$(dirname "$src_file")
        src_base=$(basename "$src_file" .ts)

        # (a) Same-name spec (standard convention: foo.service.ts → foo.service.spec.ts)
        same_name_spec="${src_file%.ts}.spec.ts"
        if [ -f "$same_name_spec" ]; then
            SPECS_TO_RUN="${SPECS_TO_RUN}${same_name_spec}
"
        fi

        # (b) Any spec in the same directory that imports this file by basename.
        #     Matches `from "./foo.service"` or `from "./foo.controller"`.
        if [ -d "$src_dir" ]; then
            related_specs=$(grep -l "from [\"']\./${src_base}[\"']" "$src_dir"/*.spec.ts 2>/dev/null || true)
            if [ -n "$related_specs" ]; then
                SPECS_TO_RUN="${SPECS_TO_RUN}${related_specs}
"
            fi
        fi
    done

    # Deduplicate
    SPECS_TO_RUN=$(echo "$SPECS_TO_RUN" | sort -u | grep -v '^$' || true)

    for spec_file in $SPECS_TO_RUN; do
        spec_rel="${spec_file#annix-backend/}"
        if ! (cd "$ROOT_DIR/annix-backend" && npx jest "$spec_rel" --no-coverage --silent --passWithNoTests 2>/dev/null); then
            echo "  FAIL: $spec_file — spec cannot resolve dependencies (or a test in it is failing)"
            echo "        A new dependency was likely added to a service/controller imported by this spec without updating the mock providers."
            SPEC_FAIL=1
        fi
    done

    if [ $SPEC_FAIL -eq 1 ]; then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Spec dependency mismatch"
        echo "============================================"
        echo "Add missing mock providers to the failing spec file(s)."
        echo ""
        exit 1
    fi
    echo "Spec dependency check passed."
fi

# 3. Frontend type-check if any frontend TS/TSX files changed
STAGED_FRONTEND_TS=$(echo "$STAGED_TS_FILES" | grep -E '^annix-frontend/src/.*\.(ts|tsx)$' || true)

if [ -n "$STAGED_FRONTEND_TS" ]; then
    echo ""
    echo "Running frontend ESLint on staged files..."
    FRONTEND_LINT_FILES=$(echo "$STAGED_FRONTEND_TS" | sed 's#^annix-frontend/##' | tr '\n' ' ')
    if ! (cd "$ROOT_DIR/annix-frontend" && pnpm eslint $FRONTEND_LINT_FILES); then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Frontend ESLint errors"
        echo "============================================"
        echo "Run 'cd annix-frontend && pnpm lint' to see all frontend lint errors."
        echo ""
        exit 1
    fi
    echo "Frontend ESLint passed."

    # Sync the stale prod typed-route cache with the current dev cache before tsc.
    # Next.js maintains .next/types/routes.d.ts (updated by `next build`) and
    # .next/dev/types/routes.d.ts (updated by the dev server on hot reload). When
    # a new route is added during a dev session, only the dev cache updates, and
    # tsc blows up with a "Type 'Route' does not satisfy the constraint 'LayoutRoutes'"
    # error. Copying dev → prod is safe because both files have identical structure
    # and `next build` will regenerate the prod cache on the next pre-push run.
    DEV_ROUTES="$ROOT_DIR/annix-frontend/.next/dev/types/routes.d.ts"
    PROD_ROUTES="$ROOT_DIR/annix-frontend/.next/types/routes.d.ts"
    if [ -f "$DEV_ROUTES" ] && [ -f "$PROD_ROUTES" ]; then
        if ! cmp -s "$DEV_ROUTES" "$PROD_ROUTES"; then
            cp "$DEV_ROUTES" "$PROD_ROUTES"
            echo "  (synced .next/types/routes.d.ts ← .next/dev/types/routes.d.ts)"
        fi
    fi

    echo "Running frontend type-check..."
    if ! (cd "$ROOT_DIR/annix-frontend" && npx tsc --noEmit 2>/dev/null); then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: TypeScript errors detected"
        echo "============================================"
        echo "Run 'cd annix-frontend && npx tsc --noEmit' to see errors."
        echo ""
        exit 1
    fi
    echo "Frontend type-check passed."

    # Long-Running Operations audit (NON-BLOCKING) — flags any staged extraction/
    # analyze/re-extract call-site missing a progress popup, per CLAUDE.md →
    # "Long-Running Operations". This never blocks the commit; it's an active
    # reminder so the popup-timer directive gets applied to old + new code alike.
    STAGED_FRONTEND_TSX=$(echo "$STAGED_FRONTEND_TS" | grep -E '\.tsx$' || true)
    if [ -n "$STAGED_FRONTEND_TSX" ]; then
        node "$ROOT_DIR/scripts/audit-extraction-progress.mjs" $STAGED_FRONTEND_TSX || true
    fi
fi

# 4. SWC landmine check — two passes against staged frontend files. SWC
#    (webpack and Turbopack) miscompiles `obj.prop ?? val`, `obj.prop || val`,
#    `obj?.prop ?? val`, `obj?.prop || val`, `arr[x] ?? val`, `arr[x] || val`
#    into an undeclared `_obj_prop` / `_ref` temp and crashes the page with
#    `ReferenceError: _ref is not defined` at runtime. CLAUDE.md's
#    "SWC-Safe Patterns" section documents the rule: hoist the access
#    into a plain local identifier first, then use that. Tsc and build
#    both PASS because the bug is in SWC's runtime output, not the source.
#    Only a user clicking the page reveals the crash — hence the pre-commit
#    check. See feedback_pre_push_failures.md #19 for the fix patterns.
#
#    PASS A — full-file scan for the highest-signal variants (optional-chain
#    and bracket access combined with ?? / ||). These have low false-positive
#    rates and the codebase has been audited clean of them.
#
#    PASS B — added-lines-only scan for plain `obj.prop ?? val` and
#    `obj.prop || val`. The codebase has thousands of pre-existing instances
#    of these (4898 `.prop ||` matches alone) so a full-file scan is not
#    feasible — restricting to lines being added in the current commit
#    prevents NEW landmines from landing without blocking on legacy code.
if [ -n "$STAGED_FRONTEND_TS" ]; then
    SWC_LANDMINES=0
    SWC_REPORT=""

    # Pass A: full-file high-signal patterns
    for f in $STAGED_FRONTEND_TS; do
        if [ -f "$f" ]; then
            MATCHES=$(git show ":$f" 2>/dev/null | grep -nE '(\?\.\w+ \?\?|\?\.\w+ \|\||\[[^]]+\] \?\?|\[[^]]+\] \|\|)' || true)
            if [ -n "$MATCHES" ]; then
                SWC_LANDMINES=1
                SWC_REPORT="${SWC_REPORT}
  $f (full-file):
$(echo "$MATCHES" | sed 's/^/    /')"
            fi
        fi
    done

    # Pass B: added-lines-only check for plain `.prop ?? / .prop ||`
    for f in $STAGED_FRONTEND_TS; do
        if [ -f "$f" ]; then
            ADDED_MATCHES=$(git diff --cached -- "$f" 2>/dev/null \
                | grep -E '^\+' \
                | grep -vE '^\+\+\+' \
                | grep -nE '\.\w+ \?\?|\.\w+ \|\|' \
                | grep -vE '\?\.\w+ \?\?|\?\.\w+ \|\|' \
                || true)
            if [ -n "$ADDED_MATCHES" ]; then
                SWC_LANDMINES=1
                SWC_REPORT="${SWC_REPORT}
  $f (added lines):
$(echo "$ADDED_MATCHES" | sed 's/^/    /')"
            fi
        fi
    done

    if [ $SWC_LANDMINES -eq 1 ]; then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: SWC landmine pattern detected"
        echo "============================================"
        echo ""
        echo "The following patterns miscompile under SWC and crash at runtime"
        echo "with 'ReferenceError: _ref is not defined':"
        printf "%s\n" "$SWC_REPORT"
        echo ""
        echo "Fix: hoist the optional-chain, bracket access, or member access"
        echo "into a plain local const first, then use the identifier."
        echo "  BAD   const v = obj?.prop ?? fallback"
        echo "  BAD   const v = arr[i] ?? fallback"
        echo "  BAD   const v = obj.prop || fallback"
        echo "  GOOD  const p = obj.prop; const v = p == null ? fallback : p"
        echo ""
        echo "See CLAUDE.md 'SWC-Safe Patterns' and feedback_pre_push_failures.md #19."
        echo ""
        exit 1
    fi
fi

# 5. Backend type-check if any backend TS files changed
STAGED_BACKEND_TS=$(echo "$STAGED_TS_FILES" | grep -E '^annix-backend/src/.*\.ts$' | grep -v '\.spec\.ts$' || true)

if [ -n "$STAGED_BACKEND_TS" ]; then
    echo ""
    echo "Running backend type-check..."
    if ! (cd "$ROOT_DIR/annix-backend" && npx tsc --noEmit 2>/dev/null); then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Backend TypeScript errors"
        echo "============================================"
        echo "Run 'cd annix-backend && npx tsc --noEmit' to see errors."
        echo ""
        exit 1
    fi
    echo "Backend type-check passed."
fi

# 6. Migration column validation — cross-check INSERT INTO column names
#    against the actual entity @Column() definitions. Catches mismatches like
#    "role_id" vs "app_role_id" that compile fine but crash at deploy time.
#    Uses sed/awk instead of grep -P for Git Bash (Windows) compatibility.
STAGED_MIGRATIONS=$(echo "$STAGED_FILES" | grep -E '^annix-backend/src/migrations/.*\.ts$' || true)

if [ -n "$STAGED_MIGRATIONS" ]; then
    echo ""
    echo "Checking migration column names against entity definitions..."
    MIG_ERR_FILE=$(mktemp)
    echo "0" > "$MIG_ERR_FILE"

    for mig_file in $STAGED_MIGRATIONS; do
        if [ ! -f "$mig_file" ]; then
            continue
        fi

        mig_content=$(git show ":$mig_file" 2>/dev/null || cat "$mig_file")

        # Extract lines with INSERT INTO "tablename" ("col1", "col2", ...)
        insert_lines=$(echo "$mig_content" | grep -i 'INSERT INTO' || true)
        if [ -z "$insert_lines" ]; then
            continue
        fi

        echo "$insert_lines" | while IFS= read -r line; do
            table=$(echo "$line" | sed -n 's/.*INSERT INTO[[:space:]]*"\([^"]*\)".*/\1/p')
            if [ -z "$table" ]; then
                continue
            fi

            col_part=$(echo "$line" | sed -n 's/.*INSERT INTO[[:space:]]*"[^"]*"[[:space:]]*(\([^)]*\)).*/\1/p')
            if [ -z "$col_part" ]; then
                continue
            fi

            entity_file=$(grep -rl "@Entity(\"$table\")" "$ROOT_DIR/annix-backend/src/" --include="*.entity.ts" 2>/dev/null | head -1 || true)
            if [ -z "$entity_file" ]; then
                continue
            fi

            columns=$(echo "$col_part" | tr ',' '\n' | sed 's/[" ]//g' | sed '/^$/d')

            for col in $columns; do
                case "$col" in
                    id|created_at|updated_at|\$*|"") continue ;;
                esac

                if ! grep -qE "name:[[:space:]]*[\"']${col}[\"']" "$entity_file" 2>/dev/null; then
                    echo "  WARNING: Migration $mig_file inserts column \"$col\" into table \"$table\""
                    echo "           but no @Column/@JoinColumn with name: \"$col\" found in $(basename $entity_file)"
                    cur=$(cat "$MIG_ERR_FILE")
                    echo "$((cur + 1))" > "$MIG_ERR_FILE"
                fi
            done
        done
    done

    MIGRATION_ERRORS=$(cat "$MIG_ERR_FILE")
    rm -f "$MIG_ERR_FILE"

    if [ "$MIGRATION_ERRORS" -gt 0 ]; then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Migration column mismatch"
        echo "============================================"
        echo "Found $MIGRATION_ERRORS column(s) in migration INSERT/UPDATE"
        echo "statements that don't match entity @Column definitions."
        echo "Verify column names by reading the entity file."
        echo ""
        exit 1
    fi
    echo "Migration column check passed."

    # 6b. Migration enum-name validation — cross-check ALTER TYPE / DROP TYPE /
    #     WHERE typname = '...' references against CREATE TYPE statements in
    #     prior migrations. Catches typos like "rubber_au_cocs_status_enum" vs
    #     "au_coc_status_enum" that pass tsc/build but crash Fly's
    #     release_command with `type "<name>" does not exist`.
    echo ""
    echo "Checking migration enum-type names against CREATE TYPE statements..."
    ENUM_ERR_FILE=$(mktemp)
    echo "0" > "$ENUM_ERR_FILE"

    for mig_file in $STAGED_MIGRATIONS; do
        if [ ! -f "$mig_file" ]; then
            continue
        fi

        mig_content=$(git show ":$mig_file" 2>/dev/null || cat "$mig_file")

        # Extract referenced enum names from ALTER TYPE / DROP TYPE / WHERE typname.
        # Patterns:
        #   ALTER TYPE foo_enum ...           (unquoted)
        #   ALTER TYPE "foo_enum" ...         (quoted)
        #   DROP TYPE [IF EXISTS] foo_enum
        #   WHERE typname = 'foo_enum'
        ref_names=$(echo "$mig_content" \
            | sed -nE 's/.*ALTER[[:space:]]+TYPE[[:space:]]+"?([a-zA-Z_][a-zA-Z0-9_]*)"?.*/\1/p; s/.*DROP[[:space:]]+TYPE[[:space:]]+(IF[[:space:]]+EXISTS[[:space:]]+)?"?([a-zA-Z_][a-zA-Z0-9_]*)"?.*/\2/p; s/.*typname[[:space:]]*=[[:space:]]*'"'"'([a-zA-Z_][a-zA-Z0-9_]*)'"'"'.*/\1/p' \
            | sort -u | grep -v '^$' || true)

        if [ -z "$ref_names" ]; then
            continue
        fi

        for enum_name in $ref_names; do
            # Search for CREATE TYPE "<name>" in:
            # (a) the same migration file
            # (b) any other migration file
            # (c) any entity file (in case the enum is created via @Column type:"enum")
            if grep -qE "CREATE[[:space:]]+TYPE[[:space:]]+\"?${enum_name}\"?" \
                "$ROOT_DIR/annix-backend/src/migrations/"*.ts 2>/dev/null; then
                continue
            fi

            echo "  WARNING: Migration $mig_file references enum \"$enum_name\""
            echo "           but no CREATE TYPE \"$enum_name\" found in any migration."
            echo "           Common fix: grep for the actual enum name in migrations/."
            cur=$(cat "$ENUM_ERR_FILE")
            echo "$((cur + 1))" > "$ENUM_ERR_FILE"
        done
    done

    ENUM_ERRORS=$(cat "$ENUM_ERR_FILE")
    rm -f "$ENUM_ERR_FILE"

    if [ "$ENUM_ERRORS" -gt 0 ]; then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Migration enum-type mismatch"
        echo "============================================"
        echo "Found $ENUM_ERRORS reference(s) to enum types that have no"
        echo "matching CREATE TYPE in the migrations folder."
        echo "Fly's release_command will crash with"
        echo "  error: type \"<name>\" does not exist"
        echo "Verify the enum name by grepping migrations/ for the real name."
        echo ""
        exit 1
    fi
    echo "Migration enum-type check passed."

    # 6c. Migration FK-reference validation — cross-check FOREIGN KEY ...
    #     REFERENCES "<table>" against the real table name. Catches
    #     singular/plural typos like "rubber_companies" vs "rubber_company"
    #     that pass tsc/build/biome AND pre-push (which only runs migrations
    #     against a DB where they're already applied), then crash Fly's
    #     release_command on a fresh DB with `relation "<name>" does not exist`,
    #     taking prod down. A referenced table is valid if it appears as an
    #     @Entity("<table>") in any entity file OR a CREATE TABLE "<table>" in
    #     any migration. (See feedback_pre_push_failures.md #66.)
    echo ""
    echo "Checking migration FK references against entity / CREATE TABLE names..."
    FK_ERR_FILE=$(mktemp)
    echo "0" > "$FK_ERR_FILE"

    for mig_file in $STAGED_MIGRATIONS; do
        if [ ! -f "$mig_file" ]; then
            continue
        fi

        mig_content=$(git show ":$mig_file" 2>/dev/null || cat "$mig_file")

        # Extract the table name after each FOREIGN KEY ... REFERENCES.
        # Matches REFERENCES "tbl"(...), REFERENCES tbl(...), REFERENCES "tbl" (...)
        ref_tables=$(echo "$mig_content" \
            | sed -nE 's/.*REFERENCES[[:space:]]+"?([a-zA-Z_][a-zA-Z0-9_]*)"?.*/\1/p' \
            | sort -u | grep -v '^$' || true)

        if [ -z "$ref_tables" ]; then
            continue
        fi

        for tbl in $ref_tables; do
            # (a) @Entity("<tbl>") / @Entity('<tbl>') / @Entity({ name: "<tbl>" })
            if grep -rqE "@Entity\([^)]*[\"']${tbl}[\"']" \
                "$ROOT_DIR/annix-backend/src/" --include="*.entity.ts" 2>/dev/null; then
                continue
            fi
            # (b) CREATE TABLE [IF NOT EXISTS] "<tbl>" in any migration (incl. this one)
            if grep -qE "CREATE[[:space:]]+TABLE[[:space:]]+(IF[[:space:]]+NOT[[:space:]]+EXISTS[[:space:]]+)?\"?${tbl}\"?" \
                "$ROOT_DIR/annix-backend/src/migrations/"*.ts 2>/dev/null; then
                continue
            fi

            echo "  WARNING: Migration $mig_file FK references table \"$tbl\""
            echo "           but no @Entity(\"$tbl\") or CREATE TABLE \"$tbl\" found."
            echo "           Likely a singular/plural typo (e.g. rubber_company vs rubber_companies)."
            echo "           Verify with: grep -rn '@Entity(' annix-backend/src/**/entities/"
            cur=$(cat "$FK_ERR_FILE")
            echo "$((cur + 1))" > "$FK_ERR_FILE"
        done
    done

    FK_ERRORS=$(cat "$FK_ERR_FILE")
    rm -f "$FK_ERR_FILE"

    if [ "$FK_ERRORS" -gt 0 ]; then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Migration FK-reference mismatch"
        echo "============================================"
        echo "Found $FK_ERRORS FOREIGN KEY reference(s) to a table with no"
        echo "matching @Entity or CREATE TABLE. Fly's release_command will crash"
        echo "with: relation \"<name>\" does not exist (deploy aborts, prod down)."
        echo "Fix the table name in the migration (check singular vs plural)."
        echo ""
        exit 1
    fi
    echo "Migration FK-reference check passed."
fi

# === HOW-TO GUIDE RELEVANCE PROMPT (BLOCKING) ===
# Auto-discovers all how-to guides under annix-frontend/src/app/*/how-to/guides/,
# matches their `relatedPaths` against staged files, and prompts the engineer
# to edit / bump / skip-with-reason / draft-with-claude before the commit lands.
# `skip` requires a one-line reason which is recorded in .git/HOWTO_SKIP_REASONS
# and appended as a `Howto-Skip:` trailer by the commit-msg hook.
# Honours HOWTO_HOOK=skip and the standard --no-verify escape hatch.
if [ -f "$ROOT_DIR/scripts/howto-pre-commit-prompt.ts" ]; then
    if ! node "$ROOT_DIR/scripts/howto-pre-commit-prompt.ts"; then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: How-To guide prompt aborted"
        echo "============================================"
        echo "Run 'HOWTO_HOOK=skip git commit ...' to bypass entirely,"
        echo "or 'git commit --no-verify' to skip ALL pre-commit checks."
        echo ""
        exit 1
    fi
fi
