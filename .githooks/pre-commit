#!/bin/bash
#
# Pre-commit hook for secret detection
# Requirements: bash, grep (works with Git Bash on Windows, native on macOS/Linux)
#

set -e

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SECRETS_PATTERNS_FILE="$ROOT_DIR/.secret-patterns"

echo "Running secret detection scan..."

# Get staged files (only text files, exclude certain paths)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -v -E '(\.secret-patterns|pnpm-lock\.yaml|package-lock\.json|\.gitignore|\.githooks/)' || true)

if [ -z "$STAGED_FILES" ]; then
    echo "No files to scan."
    exit 0
fi

FOUND_SECRETS=0

# Check for literal patterns from the secrets pattern file (fixed-string matching)
if [ -f "$SECRETS_PATTERNS_FILE" ]; then
    while IFS= read -r pattern || [ -n "$pattern" ]; do
        # Skip empty lines and comments
        case "$pattern" in
            ''|\#*) continue ;;
        esac

        for file in $STAGED_FILES; do
            if [ -f "$file" ]; then
                # Search for literal string in the staged version of the file (-F = fixed strings)
                if git show ":$file" 2>/dev/null | grep -qF "$pattern"; then
                    echo "ERROR: Potential secret found in $file"
                    echo "  Pattern: $pattern"
                    FOUND_SECRETS=1
                fi
            fi
        done
    done < "$SECRETS_PATTERNS_FILE"
fi

# Additional checks for common secret patterns
COMMON_PATTERNS=(
    # AWS Access Key ID
    'AKIA[0-9A-Z]{16}'

    # JWT secrets (64-char hex)
    'JWT_SECRET.*[a-f0-9]{64}'

    # Private keys
    'BEGIN.*PRIVATE KEY'

    # Fly.io tokens
    'FlyV1.*fm2_'

    # Google API keys
    'AIza[0-9A-Za-z_-]{35}'
)

for pattern in "${COMMON_PATTERNS[@]}"; do
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            if git show ":$file" 2>/dev/null | grep -qE "$pattern"; then
                echo "ERROR: Potential secret pattern found in $file"
                echo "  Pattern type: $(printf '%.50s' "$pattern")..."
                FOUND_SECRETS=1
            fi
        fi
    done
done

if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo "=========================================="
    echo "COMMIT BLOCKED: Potential secrets detected"
    echo "=========================================="
    echo ""
    echo "If these are false positives, you can:"
    echo "  1. Add the pattern to .secret-patterns with a comment explaining why it's safe"
    echo "  2. Use 'git commit --no-verify' to bypass (NOT RECOMMENDED)"
    echo ""
    exit 1
fi

echo "Secret scan passed - no secrets detected."

# Version bump check for app changes
check_version_bump() {
    local app_name="$1"
    local version_file="$2"
    shift 2
    local frontend_patterns=("$@")

    local files_changed=0
    for pattern in "${frontend_patterns[@]}"; do
        local count=$(git diff --cached --name-only --diff-filter=ACMR | grep -c "^${pattern}" || true)
        files_changed=$((files_changed + count))
    done

    local version_changed=$(git diff --cached --name-only --diff-filter=ACMR | grep -c "^${version_file}$" || true)

    if [ "$files_changed" -gt 0 ] && [ "$version_changed" -eq 0 ]; then
        local non_test=$(git diff --cached --name-only --diff-filter=ACMR | grep -E "$(printf '%s|' "${frontend_patterns[@]}" | sed 's/|$//')" | grep -cvE '\.(spec|test)\.ts$' || true)
        if [ "$non_test" -gt 0 ]; then
            echo ""
            echo "  WARNING: ${app_name} files changed but version not bumped."
            echo "   Remember to update: $version_file"
            echo "   (patch for fixes, minor for features, major for breaking changes)"
            echo ""
        fi
    fi
}

check_version_bump "Stock Control" \
    "annix-frontend/src/app/stock-control/config/version.ts" \
    "annix-frontend/src/app/stock-control/" "annix-backend/src/stock-control/"

check_version_bump "RFQ" \
    "annix-frontend/src/app/lib/config/rfq/version.ts" \
    "annix-frontend/src/app/admin/" "annix-frontend/src/app/customer/" "annix-frontend/src/app/supplier/" "annix-frontend/src/app/lib/config/rfq/" "annix-backend/src/rfq/" "annix-backend/src/boq/"

check_version_bump "AU Rubber" \
    "annix-frontend/src/app/au-rubber/config/version.ts" \
    "annix-frontend/src/app/au-rubber/" "annix-backend/src/au-rubber/"

check_version_bump "FieldFlow/Voice" \
    "annix-frontend/src/app/fieldflow/config/version.ts" \
    "annix-frontend/src/app/fieldflow/"

check_version_bump "Annix Rep" \
    "annix-frontend/src/app/fieldflow/config/annix-rep-version.ts" \
    "annix-frontend/src/app/fieldflow/"

check_version_bump "CV Assistant" \
    "annix-frontend/src/app/cv-assistant/config/version.ts" \
    "annix-frontend/src/app/cv-assistant/" "annix-backend/src/cv-assistant/"

# ─── Fast pre-commit checks ────────────────────────────────────────────
# These catch issues that otherwise only surface during the slow pre-push
# pipeline (biome, type-check, spec dependency mismatches).

STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|json)$' || true)

# 1. Biome lint on staged files only (prevents formatting failures at push)
if [ -n "$STAGED_TS_FILES" ]; then
    echo ""
    echo "Running biome check on staged files..."
    # Build file list for biome (one per line → space-separated)
    BIOME_FILES=$(echo "$STAGED_TS_FILES" | tr '\n' ' ')
    if ! pnpm biome check $BIOME_FILES 2>/dev/null; then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Biome check failed"
        echo "============================================"
        echo "Run 'npx biome check --write --unsafe .' to auto-fix."
        echo ""
        exit 1
    fi
    echo "Biome check passed."
fi

# 2. Backend spec dependency check — if a service constructor changed,
#    verify its spec file can still resolve all providers.
STAGED_BACKEND_SERVICES=$(echo "$STAGED_TS_FILES" | grep -E '^annix-backend/src/.*\.service\.ts$' | grep -v '\.spec\.ts$' || true)

if [ -n "$STAGED_BACKEND_SERVICES" ]; then
    echo ""
    echo "Checking backend spec dependencies for changed services..."
    SPEC_FAIL=0
    for svc_file in $STAGED_BACKEND_SERVICES; do
        spec_file="${svc_file%.ts}.spec.ts"
        if [ -f "$spec_file" ]; then
            # Quick dry-run: run only the "should be defined" test for this spec
            spec_rel="${spec_file#annix-backend/}"
            if ! (cd "$ROOT_DIR/annix-backend" && npx jest "$spec_rel" --no-coverage -t "should be defined" --silent 2>/dev/null); then
                echo "  FAIL: $spec_file — spec cannot resolve service dependencies"
                echo "        A new dependency was likely added to $(basename "$svc_file") without updating the spec."
                SPEC_FAIL=1
            fi
        fi
    done
    if [ $SPEC_FAIL -eq 1 ]; then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Spec dependency mismatch"
        echo "============================================"
        echo "Add missing mock providers to the failing spec file(s)."
        echo ""
        exit 1
    fi
    echo "Spec dependency check passed."
fi

# 3. Frontend type-check if any frontend TS/TSX files changed
STAGED_FRONTEND_TS=$(echo "$STAGED_TS_FILES" | grep -E '^annix-frontend/src/.*\.(ts|tsx)$' || true)

if [ -n "$STAGED_FRONTEND_TS" ]; then
    echo ""
    echo "Running frontend type-check..."
    if ! (cd "$ROOT_DIR/annix-frontend" && npx tsc --noEmit 2>/dev/null); then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: TypeScript errors detected"
        echo "============================================"
        echo "Run 'cd annix-frontend && npx tsc --noEmit' to see errors."
        echo ""
        exit 1
    fi
    echo "Frontend type-check passed."
fi

# 4. Backend type-check if any backend TS files changed
STAGED_BACKEND_TS=$(echo "$STAGED_TS_FILES" | grep -E '^annix-backend/src/.*\.ts$' | grep -v '\.spec\.ts$' || true)

if [ -n "$STAGED_BACKEND_TS" ]; then
    echo ""
    echo "Running backend type-check..."
    if ! (cd "$ROOT_DIR/annix-backend" && npx tsc --noEmit 2>/dev/null); then
        echo ""
        echo "============================================"
        echo "COMMIT BLOCKED: Backend TypeScript errors"
        echo "============================================"
        echo "Run 'cd annix-backend && npx tsc --noEmit' to see errors."
        echo ""
        exit 1
    fi
    echo "Backend type-check passed."
fi
