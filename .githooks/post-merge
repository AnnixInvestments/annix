#!/usr/bin/env bash
# Runs after `git pull` / `git merge` (core.hooksPath=.githooks).
#
# Why this exists: after a large pull, the Next.js dev server's persistent
# webpack cache (annix-frontend/.next) holds module IDs that point at chunks
# the pulled code changed. The swarm recompiles on file change but reuses that
# stale cache, so the browser hits "Element type is invalid / Lazy element type
# must resolve to a class or function". The only reliable cure is a cold
# rebuild from an empty .next plus a browser hard-refresh. This hook makes the
# cold rebuild automatic so a stale cache never survives a big pull again.
#
# Does NOT run on `git pull --rebase` (Git skips post-merge there) — use a
# plain `git pull`, or restart the frontend from the swarm afterwards.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$ROOT" || exit 0

changed="$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null)" || exit 0

frontend_changed="$(printf '%s\n' "$changed" | grep -c '^annix-frontend/' || true)"
deps_changed="$(printf '%s\n' "$changed" | grep -cE '^annix-frontend/(package\.json|next\.config\.|pnpm-lock\.yaml)|^pnpm-lock\.yaml$' || true)"

THRESHOLD="${ANNIX_NEXT_RESET_THRESHOLD:-12}"

if [ "$frontend_changed" -lt "$THRESHOLD" ] && [ "$deps_changed" -eq 0 ]; then
  exit 0
fi

NEXT_DIR="annix-frontend/.next"
if [ -d "$NEXT_DIR" ]; then
  staging="${NEXT_DIR}.stale.$$"
  if mv "$NEXT_DIR" "$staging" 2>/dev/null; then
    (rm -rf "$staging" 2>/dev/null &)
  else
    rm -rf "$NEXT_DIR" 2>/dev/null || true
  fi
fi

printf '\n\033[1;33m[post-merge]\033[0m Big frontend pull (%s files changed) — cleared %s for a clean rebuild.\n' "$frontend_changed" "$NEXT_DIR"
printf '\033[1;33m[post-merge]\033[0m Next: in the Claude Swarm window press \033[1ma\033[0m (Restart apps), then hard-refresh the browser (\033[1mCmd+Shift+R\033[0m).\n\n'

exit 0
