{
  "branchPrefix": "claude/",
  "apps": [
    {
      "name": "backend",
      "start": { "mac": "./run-backend.sh", "windows": ".\\run-backend.ps1" },
      "readyPattern": "Nest application successfully started",
      "readyTimeoutMs": 360000,
      "port": 4001,
      "health": "http://localhost:4001/health"
    },
    {
      "name": "frontend",
      "start": { "mac": "./run-frontend.sh", "windows": ".\\run-frontend.ps1" },
      "readyPattern": "Ready in",
      "readyTimeoutMs": 120000,
      "port": 3000
    }
  ],
  "envDir": "annix-backend/configs",
  "profiles": {
    "staging": {
      "description": "Staging Mongo (annix_staging). Uploads use prod S3 bucket. Email off locally.",
      "env": {
        "provider": "flyio",
        "app": "annix-app-staging",
        "secrets": [
          "DATABASE_DRIVER",
          "MONGODB_URI",
          "MONGO_DATABASE",
          "JWT_SECRET",
          "DOCUMENT_ENCRYPTION_KEY",
          "AWS_ACCESS_KEY_ID",
          "AWS_SECRET_ACCESS_KEY",
          "AWS_REGION",
          "AWS_S3_BUCKET",
          "GEMINI_API_KEY",
          "ANTHROPIC_API_KEY",
          "TOKEN_ENCRYPTION_KEY"
        ]
      },
      "localOverrides": {
        "FRONTEND_URL": "http://localhost:3000",
        "CORS_ORIGINS": "http://localhost:3000",
        "EMAIL_DELIVERY_DISABLED": "true"
      }
    },
    "test": {
      "description": "Test Mongo (annix_test). Uploads use prod S3 bucket. Email off locally.",
      "env": {
        "provider": "flyio",
        "app": "annix-app-test",
        "secrets": [
          "DATABASE_DRIVER",
          "MONGODB_URI",
          "MONGO_DATABASE",
          "JWT_SECRET",
          "DOCUMENT_ENCRYPTION_KEY",
          "AWS_ACCESS_KEY_ID",
          "AWS_SECRET_ACCESS_KEY",
          "AWS_REGION",
          "AWS_S3_BUCKET",
          "GEMINI_API_KEY",
          "ANTHROPIC_API_KEY",
          "TOKEN_ENCRYPTION_KEY"
        ]
      },
      "localOverrides": {
        "FRONTEND_URL": "http://localhost:3000",
        "CORS_ORIGINS": "http://localhost:3000",
        "EMAIL_DELIVERY_DISABLED": "true"
      }
    },
    "production": {
      "description": "LIVE production Mongo (annix_production) + prod S3. Real customer data. Email off locally.",
      "env": {
        "provider": "flyio",
        "app": "annix-app",
        "secrets": [
          "DATABASE_DRIVER",
          "MONGODB_URI",
          "MONGO_DATABASE",
          "JWT_SECRET",
          "DOCUMENT_ENCRYPTION_KEY",
          "AWS_ACCESS_KEY_ID",
          "AWS_SECRET_ACCESS_KEY",
          "AWS_REGION",
          "AWS_S3_BUCKET",
          "GEMINI_API_KEY",
          "ANTHROPIC_API_KEY",
          "TOKEN_ENCRYPTION_KEY"
        ]
      },
      "localOverrides": {
        "FRONTEND_URL": "http://localhost:3000",
        "CORS_ORIGINS": "http://localhost:3000",
        "EMAIL_DELIVERY_DISABLED": "true"
      }
    }
  }
}
